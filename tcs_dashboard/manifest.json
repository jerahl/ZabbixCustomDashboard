{
    "manifest_version": 2.0,
    "id": "tcs_dashboard",
    "name": "TCS Dashboard",
    "version": "1.3.0",
    "namespace": "TcsDashboard",
    "description": "Custom-skinned operations dashboards for Zabbix (TCS / Extreme / PacketFence / Milestone XProtect).",
    "author": "TCS Networking",
    "url": "",
    "actions": {
        "tcs.global.view": {
            "class": "ActionGlobal",
            "view": "global.view",
            "layout": "layout.htmlpage"
        },
        "tcs.global.data": {
            "class": "ActionGlobalData",
            "layout": "layout.json",
            "view": null
        },
        "tcs.dashboard.view": {
            "class": "ActionDashboard",
            "view": "dashboard.view",
            "layout": "layout.htmlpage"
        },
        "tcs.dashboard.data": {
            "class": "ActionDashboardData",
            "layout": "layout.json",
            "view": null
        },
        "tcs.surveillance.view": {
            "class": "ActionSurveillance",
            "view": "surveillance.view",
            "layout": "layout.htmlpage"
        },
        "tcs.switches.view": {
            "class": "ActionSwitches",
            "view": "switches.view",
            "layout": "layout.htmlpage"
        },
        "tcs.switches.fleet.data": {
            "class": "ActionSwitchesFleetData",
            "layout": "layout.json",
            "view": null
        },
        "tcs.switches.snapshot.data": {
            "class": "ActionSwitchesSnapshotData",
            "layout": "layout.json",
            "view": null
        },
        "tcs.switches.port.history.data": {
            "class": "ActionSwitchesPortHistoryData",
            "layout": "layout.json",
            "view": null
        },
        "tcs.servers.view": {
            "class": "ActionServers",
            "view": "servers.view",
            "layout": "layout.htmlpage"
        },
        "tcs.servers.data": {
            "class": "ActionServersData",
            "layout": "layout.json",
            "view": null
        },
        "tcs.problems.view": {
            "class": "ActionProblems",
            "view": "problems.view",
            "layout": "layout.htmlpage"
        },
        "tcs.problems.data": {
            "class": "ActionProblemsData",
            "layout": "layout.json",
            "view": null
        },
        "tcs.events.view": {
            "class": "ActionEvents",
            "view": "events.view",
            "layout": "layout.htmlpage"
        },
        "tcs.events.data": {
            "class": "ActionEventsData",
            "layout": "layout.json",
            "view": null
        },
        "tcs.events.update": {
            "class": "ActionEventsUpdate",
            "layout": "layout.json",
            "view": null
        },
        "tcs.camera.view": {
            "class": "ActionCamera",
            "view": "camera.view",
            "layout": "layout.htmlpage"
        },
        "tcs.server.view": {
            "class": "ActionServer",
            "view": "server.view",
            "layout": "layout.htmlpage"
        },
        "tcs.switch.cyclepoe": {
            "class": "ActionSwitchCyclePoe",
            "layout": "layout.json",
            "view": null
        }
    }
}
